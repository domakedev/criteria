# Copia este archivo a .env.local y completa los valores.
# Ver web/README.md para los pasos detallados.

# --- Cliente (Firebase Console → Configuración del proyecto → Tus apps → Web) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Servidor (Configuración del proyecto → Cuentas de servicio → Generar clave privada) ---
# Pega el JSON completo en UNA línea, o el JSON codificado en base64.
FIREBASE_SERVICE_ACCOUNT=

# --- IA (opcional) — https://aistudio.google.com/apikey ---
# Sin clave, la app funciona igual: solo se oculta la "Lectura de la IA".
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest

