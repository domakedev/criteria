{
  "name": "criteria-mind",
  "version": "0.1.0",
  "description": "An open format and reference library for human criterion: capture, layer, query and learn from real human decisions. Human-first, AI-optional.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "criterion",
    "judgment",
    "decision-making",
    "phronesis",
    "open-format",
    "human-in-the-loop"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "criteria": "./dist/cli.js"
  },
  "files": [
    "dist",
    "spec",
    "MANIFESTO.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test \"tests/*.test.ts\"",
    "cli": "node --import tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
